# Wi-Fi test credentials
TEST_WIFI_SSID=your-ssid
TEST_WIFI_PASSWORD=your-password

# Optional serial port defaults for local development.
# When --port is not specified, pytest uses TEST_SERIAL_PORT_<PROFILE> if present.
# Otherwise it falls back to TEST_SERIAL_PORT.
# Profile names are uppercased and "-" is replaced with "_".
# Examples:
#   profile "esp32" -> TEST_SERIAL_PORT_ESP32
#   profile "esp32-s3" -> TEST_SERIAL_PORT_ESP32_S3
TEST_SERIAL_PORT=/dev/ttyUSB0
TEST_SERIAL_PORT_ESP32=/dev/ttyUSB0
